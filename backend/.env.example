# ---------------------------------------------------------------------------
# Base de datos — Supabase
# Usar la URL de Transaction Pooler (puerto 6543) para Railway/serverless.
# Se obtiene en: Supabase → Settings → Database → Connection string → URI
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Seguridad JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=180

# ---------------------------------------------------------------------------
# Twilio (SMS OTP)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ---------------------------------------------------------------------------
# CORS
# Lista separada por comas. Agregar el dominio del frontend en producción.
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=https://tecnoamigo.vercel.app,http://localhost:3000

# ---------------------------------------------------------------------------
# Entorno
# ---------------------------------------------------------------------------
ENVIRONMENT=production
